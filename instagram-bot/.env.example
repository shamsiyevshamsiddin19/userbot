# ===== Instagram / Meta =====
# Meta Developer app'dan olinadi (README'ga qarang)
IG_ACCESS_TOKEN=bu_yerga_instagram_access_token
IG_ACCOUNT_ID=bu_yerga_instagram_business_account_id

# Webhook'ni tekshirish uchun o'zingiz o'ylab topadigan maxfiy so'z
VERIFY_TOKEN=mening_maxfiy_sozim_123

# ===== Gemini =====
# https://aistudio.google.com/apikey dan bepul olinadi
GEMINI_API_KEY=bu_yerga_gemini_token
GEMINI_MODEL=gemini-flash-latest

# ===== Bot xatti-harakati =====
# Bot o'zini qanday tutsin (o'zingizga moslang)
BOT_PERSONA=Sen do'stona, hurmatli va qisqa javob beradigan Instagram yordamchisisan. O'zbek tilida javob ber. Emoji ishlatishing mumkin, lekin ozroq.

# Har bir javob maksimal uzunligi (belgilarda)
MAX_REPLY_CHARS=500
